{
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "frontend:dev": "vite --host 0.0.0.0",
    "frontend:build": "vite build",
    "dev": "tsx src/backend/server.ts",
    "start": "node dist/backend/server.js",
    "stop": "bash tools/stop-server.sh",
    "test:basic": "bash tools/run-tests.sh basic",
    "test:filter": "bash tools/run-tests.sh filter",
    "test:agg": "bash tools/run-tests.sh agg",
    "test:anomaly": "bash tools/run-tests.sh anomaly",
    "test:bulk": "bash tools/run-tests.sh bulk",
    "test:concurrent": "bash tools/run-tests.sh concurrent",
    "test:perf": "bash tools/run-tests.sh perf",
    "test:realtime": "bash tools/run-tests.sh realtime",
    "test:security": "bash tools/run-tests.sh security",
    "grade": "bash tools/run-tests.sh grade",
    "git:init": "bash tools/agent/git-init.sh",
    "git:status": "bash tools/agent/git-status.sh",
    "git:slice": "bash tools/agent/git-slice.sh",
    "test": "bash tools/run-tests.sh all",
    "test:check": "bash tools/run-tests.sh check",
    "data:inspect": "python tools/inspect_data.py",
    "db:migrate": "tsx src/backend/db/migrate.ts",
    "data:import": "tsx src/backend/db/import.ts",
    "data:verify:categories": "tsx tools/verify_category_lookup.ts",
    "server:smoke": "tsx tools/smoke_server.ts",
    "stress:api": "vitest run --config stress-tests/vitest.config.ts stress-tests/api_stress.ts",
    "stress:cache": "npm run build && vitest run --config stress-tests/vitest.config.ts stress-tests/cache_stress.ts",
    "stress:generate-data": "python tools/generate_stress_data.py --orders 200000 --out data_stress --seed 42",
    "stress:validate-data": "vitest run --config stress-tests/vitest.config.ts stress-tests/validate_stress_dataset.ts",
    "stress:validate-api": "vitest run --config stress-tests/vitest.config.ts stress-tests/validate_stress_api.ts",
    "stress:test": "vitest run --config stress-tests/vitest.config.ts"
  },
  "dependencies": {
    "csv-parse": "^6.2.1",
    "express": "^4.19.2",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^4.7.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.4.21",
    "vitest": "^2.0.0"
  }
}
