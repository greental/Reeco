# Runtime
NODE_ENV=development
PORT=3000

# PostgreSQL defaults match docker-compose.yml
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/order_ops
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=order_ops
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis is available but optional until performance/coordination needs require it
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false
